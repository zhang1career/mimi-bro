{
  "frontend-analysis": {
    "executors": {
      "backend": {"mode": "agent", "method": "local"}
    }
  },
  "code-review": {
    "executors": {
      "reviewer": {"mode": "agent", "method": "local"}
    }
  },
  "backend-dev": {
    "invocation": {
      "type": "bro_submit",
      "task_file": "tasks/backend-dev.json",
      "workspace": "docker/workspace",
      "resource": "{src_path}",
      "local": true
    },
    "executors": {
      "backend": {"mode": "agent", "method": "local"},
      "docker-agent": {"mode": "agent", "method": "docker"}
    }
  },
  "frontend-dev": {
    "invocation": {
      "type": "bro_submit",
      "task_file": "tasks/frontend-dev.json",
      "workspace": "docker/workspace",
      "resource": "{src_path}",
      "local": true
    },
    "executors": {
      "backend": {"mode": "agent", "method": "local"}
    }
  },
  "run-linter": {
    "invocation": {
      "type": "shell",
      "template": "npm run lint -- {src_path}"
    },
    "executors": {}
  },
  "call-remote": {
    "invocation": {
      "type": "http",
      "method": "POST",
      "url": "https://api.example.com/run",
      "body": {"skill": "{skill_id}", "params": "{params_json}"}
    },
    "executors": {}
  }
}
